{
    "name": "tavp/starter",
    "description": "TAVP Stack starter template for quick project bootstrapping",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "phalcon/cphalcon": "^5.16",
        "vlucas/phpdotenv": "^5.6",
        "tavp/core": "^1.1",
        "tavp/cms": "^0.2",
        "tavp/tavphub": "^1.1",
        "tavp/tavpid": "^1.0"
    },
    "require-dev": {
        "tavp/tavpblocks": "@dev"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "bin": [
        "bin/tavp"
    ],
    "support": {
        "issues": "https://github.com/tavp-stack/tavp-starter/issues",
        "source": "https://github.com/tavp-stack/tavp-starter"
    }
}
